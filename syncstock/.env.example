# PostgreSQL
POSTGRES_USER=syncstock
POSTGRES_PASSWORD=change_me_in_prod
DATABASE_URL=postgresql://syncstock:change_me_in_prod@postgres:5432/syncstock

# Redis
REDIS_URL=redis://redis:6379

# Bling ERP
BLING_WEBHOOK_SECRET=your_bling_webhook_secret
BLING_API_KEY=your_bling_api_key
BLING_API_URL=https://www.bling.com.br/Api/v3

# JWT (rotate: move current JWT_SECRET to JWT_SECRET_PREV, set new JWT_SECRET)
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_SECRET_PREV=
JWT_ISSUER=syncstock

# WMS — Smartgo WMS (modern REST)
WMS_MODE=modern
WMS_BASE_URL=https://apigateway.smartgo.com.br
WMS_API_KEY=your_smartgo_api_key

# CNPJ do depositante (formatado: 00.000.000/0001-00)
WMS_DOC_DEPOSITANTE=00.000.000/0001-00

# Secret token embedded in the Smartgo webhook callback URL.
# Register in Smartgo: https://apigateway.smartgo.com.br → callback URL →
#   https://your-host/webhooks/wms/<WMS_WEBHOOK_TOKEN>
# Generate with: openssl rand -hex 32
WMS_WEBHOOK_TOKEN=generate_with_openssl_rand_hex_32

# Company / depositante identifier (used as companyId in DB)
WMS_COMPANY_ID=1

# Legacy WMS only — leave blank for Smartgo (modern)
WMS_DB_URL=
WMS_POLL_INTERVAL_MS=30000

# Supabase Edge Function — importar-nfe
# Opcional: se definido, todas as requisições devem incluir o header
# x-webhook-signature: sha256=<hmac-sha256-hex>
# Gere com: openssl rand -hex 32
WEBHOOK_SECRET=

# Ports (host-side)
MIDDLEWARE_PORT=3000
DASHBOARD_PORT=4000
